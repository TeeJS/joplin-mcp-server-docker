# Joplin Web Clipper API token (Joplin Desktop -> Tools -> Options -> Web Clipper)
JOPLIN_TOKEN=replace_with_your_token

# IP or hostname of the machine running Joplin Desktop, reachable from the container.
# On Unraid, this is your PC's LAN IP (e.g. 192.168.1.50).
JOPLIN_HOST=192.168.1.50
JOPLIN_PORT=41184
